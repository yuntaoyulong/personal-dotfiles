layout {
    pane split_direction="vertical" {
        pane command="/usr/bin/networkmanager_dmenu" {
            name "Network Config"
            size "50%"
        }
        pane command="/home/quaerendo/.local/bin/bluetooth-menu" {
            name "Bluetooth Config"
            size "50%"
        }
    }
    pane size=1 borderless=true {
        plugin location="zellij:compact-bar"
    }
}
